DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=YOUR_VM_PUBLIC_IP,YOUR_DOMAIN,localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://YOUR_VM_PUBLIC_IP,http://YOUR_DOMAIN,https://YOUR_DOMAIN
DJANGO_CSRF_TRUSTED_ORIGINS=http://YOUR_VM_PUBLIC_IP,http://YOUR_DOMAIN,https://YOUR_DOMAIN
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=/var/www/my_finance/backend/db.sqlite3
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
